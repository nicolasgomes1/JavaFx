<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17.0.12"
      fx:controller="com.qaflow.desktopdemo.HelloController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label fx:id="welcomeText"/>

    <HBox alignment="CENTER" spacing="10">
        <Button fx:id="hideButton" text="Hide" onAction="#onHelloButtonClickReset"/>
        <Button fx:id="showButton" text="Show" onAction="#onHelloButtonClick"/>
    </HBox>

    <HBox>
        <Label fx:id="currentText"/>
    </HBox>

</VBox>
