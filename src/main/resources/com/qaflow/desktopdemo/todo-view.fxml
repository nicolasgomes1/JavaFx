<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.qaflow.desktopdemo.controller.ToDoController">

    <center>
        <TableView fx:id="todoTable">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="60.0"/>
                <TableColumn fx:id="titleColumn" text="Title" prefWidth="180.0"/>
                <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="280.0"/>
                <TableColumn fx:id="completedColumn" text="Done" prefWidth="80.0"/>
            </columns>
        </TableView>
    </center>

    <right>
        <VBox spacing="10.0" prefWidth="300.0">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>

            <Label text="Title"/>
            <TextField fx:id="titleField"/>

            <Label text="Description"/>
            <TextArea fx:id="descriptionArea" prefRowCount="6"/>

            <CheckBox fx:id="completedCheckBox" text="Completed"/>

            <HBox spacing="8.0">
                <Button text="Add" onAction="#onAdd"/>
                <Button text="Update" onAction="#onUpdate"/>
            </HBox>

            <HBox spacing="8.0">
                <Button text="Delete" onAction="#onDelete"/>
                <Button text="Clear" onAction="#onClear"/>
            </HBox>
        </VBox>
    </right>
</BorderPane>